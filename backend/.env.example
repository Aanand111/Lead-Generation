# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=leadgen

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth Configuration ---
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# --- Cloudinary Configuration (Image Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SMS Gateway (Optional for Phase 3+) ---
MSG91_API_KEY=
TWILIO_SID=
TWILIO_AUTH_TOKEN=

# --- Email Configuration ---
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- Environment ---
NODE_ENV=development
RUNTIME_ROLE=api
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Runtime Tuning ---
API_INSTANCE_COUNT=1
WORKER_INSTANCE_COUNT=1
SCHEDULER_INSTANCE_COUNT=1
DB_MAX_CONNECTIONS=100
DB_RESERVED_CONNECTIONS=20
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_MAX_API=20
DB_POOL_MAX_WORKER=10
DB_POOL_MAX_SCHEDULER=4
REQUIRE_REDIS_FOR_STARTUP=false
REQUIRE_REDIS_FOR_READINESS=false
SCHEDULER_LOCK_KEY=leadgen:scheduler:lease
SCHEDULER_LEASE_TTL_MS=30000
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
