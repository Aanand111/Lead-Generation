generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model migrations {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  executed_at DateTime? @default(now()) @db.Timestamp(6)
}
